<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:layout_centerHorizontal="true"
        android:id="@+id/idTextView_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Text Number 1."
        android:textSize="32dp" />

    <TextView
        android:layout_centerHorizontal="true"
        android:layout_below="@+id/idTextView_1"
        android:id="@+id/idTextView_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Text Number 2."
        android:textSize="32dp" />

    <TextView
        android:layout_alignRight="@+id/idTextView_2"
        android:layout_below="@+id/idTextView_2"
        android:id="@+id/idTextView_3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Text Number 300."
        android:padding="20dp"
        android:layout_margin="20dp"
        android:textSize="32dp" />
</RelativeLayout>